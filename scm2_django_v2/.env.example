# Django 핵심 설정
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
# 복수 호스트는 쉼표로 구분 (예: localhost,127.0.0.1,example.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# 데이터베이스 (PostgreSQL)
DB_NAME=scm2_db
DB_USER=scm2_user
DB_PASSWORD=scm2pass
DB_HOST=localhost
DB_PORT=5432

# Redis (Django Channels Layer)
# 설정 시 channels_redis 백엔드로 자동 전환, 미설정 시 InMemoryChannelLayer 사용
REDIS_URL=redis://localhost:6379/0

# ── 국세청 전자세금계산서 ASP 연동 ────────────────────────────
# 미설정 시 내부 발행만 가능 (법적 효력 없음)
# 설정 시 /api/fi/tax-invoices/{id}/issue-nts/ 로 국세청에 실제 전송
#
# 1. ASP 사업자 선택 및 계약 (추천: 비즈폼, 이카운트, LG유플러스 등)
# 2. ASP사에서 발급받은 인증키를 NTS_ASP_CERT_KEY에 입력
# 3. ASP사 API URL을 NTS_ASP_BASE_URL에 입력
#
NTS_ASP_CERT_KEY=          # 필수: ASP사 발급 인증키 (예: abcd1234-efgh-5678-...)
NTS_ASP_BASE_URL=https://api.bizforms.co.kr/etax/v1   # ASP사별로 상이
NTS_ASP_PROVIDER=BIZFORMS  # BIZFORMS | ECOUNT | UPLUS
